// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AuthMode {
  EMAIL
  GOOGLE
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  ORDER
}

enum Method {
  FIAT
  CRYPTO
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  COMPLETED
}

model User {
  id            String         @id @default(uuid())
  firstName     String         @map("first_name") @db.VarChar(255)
  lastName      String         @map("last_name") @db.VarChar(255)
  username      String         @unique @db.VarChar(255)
  email         String         @unique @db.VarChar(255)
  authMode      AuthMode       @map("auth_mode")
  passwordHash  String?        @map("password_hash") @db.VarChar(255)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  books         Book[]
  bookBookmarks BookBookmark[]
  Wallet        Wallet?
  Order         Order[]
}

//NOTE: Genre might become an enum.
model Book {
  id           String         @id @default(uuid())
  title        String         @db.VarChar(255)
  author       String         @db.VarChar(255)
  genre        String         @db.VarChar(255)
  price        Int
  isMature     Boolean        @map("is_mature")
  pageCount    Int            @map("page_count")
  bookURL      String         @map("book_url") @db.VarChar(255)
  bookCoverURL String         @map("book_cover_url") @db.VarChar(255)
  dateUpdated  DateTime       @updatedAt @map("date_updated")
  dateAuthored DateTime       @map("date_authored")
  dateUploaded DateTime       @map("date_uploaded")
  userId       String         @map("user_id")
  user         User           @relation(fields: [userId], references: [id])
  bookmarks    BookBookmark[]
  OrderBook    OrderBook[]

  @@index([author, genre])
}

model BookBookmark {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  bookId    String   @map("book_id")
  book      Book     @relation(fields: [bookId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, bookId])
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  balance   Decimal  @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sentTransactions     Transaction[] @relation("SentTransactions")
  receivedTransactions Transaction[] @relation("ReceivedTransactions")
}

model Transaction {
  id                String            @id @default(uuid())
  type              TransactionType
  amount            Decimal
  senderWalletId    String?           @map("sender_wallet_id")
  recipientWalletId String?           @map("recipient_wallet_id")
  reference         String            @unique
  status            TransactionStatus @default(PENDING)
  description       String?
  metadata          Json?
  providerResponse  Json?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  orderId           String?           @map("order_id")

  senderWallet    Wallet? @relation("SentTransactions", fields: [senderWalletId], references: [id])
  recipientWallet Wallet? @relation("ReceivedTransactions", fields: [recipientWalletId], references: [id])

  order Order? @relation(fields: [orderId], references: [id])
}

model Order {
  id           String        @id @default(uuid())
  userId       String        @map("user_id")
  status       OrderStatus   @default(PENDING)
  totalAmount  Int           @map("total_amount")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  transactions Transaction[]

  user  User        @relation(fields: [userId], references: [id])
  books OrderBook[]
}

model OrderBook {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  bookId    String   @map("book_id")
  price     Int
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])
  book  Book  @relation(fields: [bookId], references: [id])

  @@unique([orderId, bookId])
}
